<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TGRMX Maintenence System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MaintenenceSystem.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/Images/Logo.png" />
</head>
<body class=" body-gradient">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light shadow-lg bg-secondary px-3">
            <a class="navbar-brand ms-5" href="/OrdenesMaquinados/Index">
                <img src="~/Images/Logo.png" alt="Logo" style="height:70px">
            </a>
            <a class="navbar-brand ms-5 fw-bold text-light" href="/OrdenesMaquinados/Index">TGRMX Maintenence System</a>
            <ul class="navbar-nav me-auto ms-5 mb-2 mb-lg-0">
                <li class="nav-item ms-5"><a class="nav-link text-light" href="/OrdenesMaquinados/Index">Home</a></li>
                <li class="nav-item ms-5"><a class="nav-link text-light" href="#">Help</a></li>
                <li class="nav-item ms-5">
                    <a class="nav-link text-light protected-link" data-target="/OrdenesMaquinados/AprobarOrden">Gestionar Ordenes</a>
                </li>

                <li class="nav-item ms-5">
                    <a class="nav-link text-light protected-link" data-target="/Empleados/Index">Empleados</a>
                </li>

                <li class="nav-item ms-5">
                    <a class="nav-link text-light protected-link" data-target="/GraficasMaquinados/Index">Graficas</a>
                </li>
            </ul>
        </nav>
    </header>

    <div class="container-fluid p-5">
        <main role="main" class="pb-0">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted text-center">
        <div class="container text-black fw-bold">
            © TGRMX Iot Department 2026 (Ver. 0.42526)
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!-- Modal de contraseña -->
<div class="modal fade" id="PasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Acceso Restringido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div id="PasswordError" class="alert alert-danger d-none">
                    Contraseña incorrecta
                </div>

                <label class="form-label">Ingrese la contraseña</label>
                <input type="password" id="AccessPassword" class="form-control" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" id="BtnValidatePassword">Acceder</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>

<script>
    let selectedUrl = null;

    // Cuando se hace clic en un link protegido
    $(".protected-link").on("click", function () {
        selectedUrl = $(this).data("target");
        $("#AccessPassword").val("");
        $("#PasswordError").addClass("d-none");

        let modal = new bootstrap.Modal(document.getElementById("PasswordModal"));
        modal.show();
    });

    // Foco automático al abrir el modal
    document.getElementById('PasswordModal').addEventListener('shown.bs.modal', function () {
        document.getElementById('AccessPassword').focus();
    });

    // Validar contraseña
    $("#BtnValidatePassword").on("click", function () {
        const password = $("#AccessPassword").val();

        const correctPassword = "tgna1400";

        if (password === correctPassword) {
            window.location.href = selectedUrl;
        } else {
            $("#PasswordError").removeClass("d-none");
        }
    });
</script>