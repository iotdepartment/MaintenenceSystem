@model MaintenenceSystem.Models.GraficasMaquinadosViewModel 
@using System.Text.Json

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="row mb-4">
    <div class="col-12">
        <div class="card mx-auto shadow-lg bg-secondary border-0 rounded rounded-pill p-3">
            <h3 class="m-0 fw-bold text-light"><i class="bi bi-bar-chart-fill"></i> Graficas Status de Ordenes de Maquinados</h3>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="card shadow-lg rounded-3">
        <div class="col-2">
        </div>
    </div>
</div>

<div class="row mb-5">
    <div class="col-4">
        <div class="card shadow-lg rounded-3">
            <div class="card-header bg-primary text-light fw-bold"> Cantidad de Ordenes por area </div>
            <div class="card-body">
                <canvas id="graficaAreas" height="150"></canvas>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card shadow-lg rounded-3">
            <div class="card-header bg-primary text-light fw-bold"> Cantidad de Ordenes por status </div>
            <div class="card-body">
                <canvas id="graficaStatus" height="150"></canvas>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card shadow-lg rounded-3">
            <div class="card-header bg-primary text-light fw-bold"> Cantidad de ordenes generadas vs cerradas </div>
            <div class="card-body">
                <canvas id="graficaGeneradasCerradas" height="150"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.Areas.Select(x => x.Area)));
        const data = @Html.Raw(JsonSerializer.Serialize(Model.Areas.Select(x => x.Total)));

        const ctx = document.getElementById('graficaAreas').getContext('2d');

        new Chart(ctx, {
            type: 'bar',
            plugins: [ChartDataLabels],
            data: {
                labels: labels,
                datasets: [{
                    label: 'Órdenes por Área',
                    data: data,
                    backgroundColor: [
                        'rgba(13, 110, 253, 0.8)',
                        'rgba(25, 135, 84, 0.8)',
                        'rgba(255, 193, 7, 0.8)',
                        'rgba(220, 53, 69, 0.8)',
                        'rgba(111, 66, 193, 0.8)'
                    ],
                    borderRadius: 8,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    datalabels: {
                        anchor: 'end',
                        align: 'top',
                        color: '#000',
                        font: {
                            weight: 'bold',
                            size: 14
                        },
                        formatter: (value) => value
                    },
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });
    </script>

    <script>
        const statusLabels = @Html.Raw(JsonSerializer.Serialize(Model.Status.Select(x => x.Status)));
        const statusData = @Html.Raw(JsonSerializer.Serialize(Model.Status.Select(x => x.Total)));

        const ctxStatus = document.getElementById('graficaStatus').getContext('2d');

        new Chart(ctxStatus, {
            type: 'bar',
            plugins: [ChartDataLabels],
            data: {
                labels: statusLabels,
                datasets: [{
                    label: 'Órdenes por Status',
                    data: statusData,
                    backgroundColor: [
                        '#6c757d', // Pendiente
                        '#0d6efd', // En proceso
                        '#ffc107', // Pausada
                        '#dc3545', // Cancelada
                        '#198754'  // Cerrada
                    ],
                    borderRadius: 8,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    datalabels: {
                        anchor: 'end',
                        align: 'top',
                        color: '#000',
                        font: { weight: 'bold', size: 14 },
                        formatter: (value) => value
                    },
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });
    </script>

    <script>
        const gcLabels = ["Generadas", "Cerradas"];
        const gcData = [
            @Model.TotalGeneradas,
            @Model.TotalCerradas
        ];

        const ctxGC = document.getElementById('graficaGeneradasCerradas').getContext('2d');

        new Chart(ctxGC, {
            type: 'bar',
            plugins: [ChartDataLabels],
            data: {
                labels: gcLabels,
                datasets: [{
                    label: 'Órdenes Generadas vs Cerradas',
                    data: gcData,
                    backgroundColor: [
                        'rgba(13, 110, 253, 0.8)',   // Generadas
                        'rgba(25, 135, 84, 0.8)'     // Cerradas
                    ],
                    borderRadius: 8,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    datalabels: {
                        anchor: 'end',
                        align: 'top',
                        color: '#000',
                        font: { weight: 'bold', size: 14 },
                        formatter: (value) => value
                    },
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });
    </script>
}
