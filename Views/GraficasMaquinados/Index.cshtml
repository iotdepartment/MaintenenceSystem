@model MaintenenceSystem.Models.GraficasMaquinadosViewModel 
@using System.Text.Json

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="row mb-4">
    <div class="col-6">
        <div class="card mx-auto shadow-lg bg-secondary border-0 rounded rounded-pill p-3">
            <h3 class="m-0 fw-bold text-light"><i class="bi bi-bar-chart-fill"></i> Graficas Status de Ordenes de Maquinados</h3>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="card bg-light border border-1 shadow-lg rounded-4 p-3">
        <form method="get" class="row g-3">
            <div class="col-auto">
                <label class="form-label fw-bold">Fecha Inicio</label>
                <input type="date" name="fechaInicio" class="form-control"
                       value="@Model.FechaInicio?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto">
                <label class="form-label fw-bold">Fecha Fin</label>
                <input type="date" name="fechaFin" class="form-control"
                       value="@Model.FechaFin?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-auto align-self-end">
                <button class="btn btn-primary"><i class="bi bi-search"></i> Filtrar</button>
            </div>

            <div class="col-auto align-self-end">
                <a href="/GraficasMaquinados/Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-counterclockwise"></i> Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-4">
        <div class="card shadow-lg rounded-4 border border-1" style="height: 360px;">
            <div class="card-header bg-primary text-light fw-bold text-center"> Cantidad de Ordenes por area </div>
            <div class="card-body">
                <canvas id="graficaAreas"></canvas>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card shadow-lg rounded-4 border border-1" style="height: 360px;">
            <div class="card-header bg-primary text-light fw-bold text-center"> Cantidad de Ordenes por status </div>
            <div class="card-body">
                <canvas id="graficaStatus"></canvas>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card shadow-lg rounded-4 border border-1" style="height: 360px;">
            <div class="card-header bg-primary text-light fw-bold text-center">
                Cantidad de ordenes generadas vs cerradas
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">

                <!-- CONTENEDOR QUE CONTROLA EL TAMAÑO -->
                <div style="max-width: 300px; width: 100%;">
                    <canvas id="graficaGeneradasCerradas"></canvas>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

    <script>

        const labels = @Html.Raw(JsonSerializer.Serialize(Model.Areas.OrderByDescending(x => x.Total).Select(x => x.Area)));

        const data = @Html.Raw(JsonSerializer.Serialize(Model.Areas.OrderByDescending(x => x.Total).Select(x => x.Total)));

        const ctx = document.getElementById('graficaAreas').getContext('2d');

        new Chart(ctx, {
            type: 'bar',
            plugins: [ChartDataLabels],
            data: {
                labels: labels,
                datasets: [{
                    label: 'Órdenes por Área',
                    data: data,
                    backgroundColor: [
                        'rgba(13, 110, 253, 0.8)',
                        'rgba(25, 135, 84, 0.8)',
                        'rgba(255, 193, 7, 0.8)',
                        'rgba(220, 53, 69, 0.8)',
                        'rgba(111, 66, 193, 0.8)'
                    ],
                    borderRadius: 8,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                layout: {
                    padding: {
                        top: 25
                    }
                },
                plugins: {
                    datalabels: {
                        anchor: 'end',
                        align: 'top',
                        color: '#000',
                        font: {
                            weight: 'bold',
                            size: 14
                        },
                        formatter: (value) => value
                    },
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });
    </script>

    <script>
        // ============================
        //   ORDENAR STATUS DESCENDENTE
        // ============================
        const statusOrdenado = @Html.Raw(
                    JsonSerializer.Serialize(
                            Model.Status
                                    .OrderByDescending(x => x.Total)
                                    .Select(x => new { x.Status, x.Total })
                    )
            );

    // Etiquetas ordenadas
    const statusLabels = statusOrdenado.map(x => x.Status);

        // Valores ordenados
        const statusData = statusOrdenado.map(x => x.Total);

        // Colores según el status
        const statusColors = statusOrdenado.map(x =>
            x.Status === "Pendiente" ? "#6c757d" :      // Gris
            x.Status === "En proceso" ? "#0d6efd" :     // Azul
            x.Status === "Pausada" ? "#ffc107" :        // Amarillo
            x.Status === "Cancelada" ? "#dc3545" :      // Rojo
            x.Status === "Cerrada" ? "#198754" :        // Verde
            "#000000"                                   // Default
        );

        // ============================
        //   GRAFICA DE STATUS
        // ============================
        const ctxStatus = document.getElementById('graficaStatus').getContext('2d');

        new Chart(ctxStatus, {
            type: 'bar',
            plugins: [ChartDataLabels],
            data: {
                labels: statusLabels,
                datasets: [{
                    label: 'Órdenes por Status',
                    data: statusData,
                    backgroundColor: statusColors,
                    borderRadius: 8,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,

                // 👇 ESPACIO EXTRA PARA QUE EL NÚMERO DE LA BARRA MÁS ALTA SE VEA
                layout: {
                    padding: {
                        top: 25
                    }
                },

                plugins: {
                    datalabels: {
                        anchor: 'end',
                        align: 'top',
                        color: '#000',
                        font: { weight: 'bold', size: 14 },
                        formatter: (value) => value
                    },
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });

    </script>

    <script>
                // Reducir tamaño al 50%
        const canvasGC = document.getElementById('graficaGeneradasCerradas');

        const gcLabels = ["Generadas", "Cerradas"];
        const gcData = [
            @Model.TotalGeneradas,
            @Model.TotalCerradas
        ];

        // Calcular porcentajes
        const totalGC = gcData.reduce((a, b) => a + b, 0);
        const gcPercent = gcData.map(v => ((v / totalGC) * 100).toFixed(1));

        const ctxGC = canvasGC.getContext('2d');

        new Chart(ctxGC, {
            type: 'pie',
            plugins: [ChartDataLabels],
            data: {
                labels: gcLabels,
                datasets: [{
                    label: 'Órdenes Generadas vs Cerradas',
                    data: gcData,
                    backgroundColor: [
                        'rgba(13, 110, 253, 0.8)',   // Generadas
                        'rgba(25, 135, 84, 0.8)'     // Cerradas
                    ],
                    borderColor: "#fff",
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    datalabels: {
                        color: "#fff",
                        font: { weight: "bold", size: 16 },
                        formatter: (value, ctx) => {
                            const i = ctx.dataIndex;
                            return `${value} (${gcPercent[i]}%)`;
                        }
                    },
                    legend: {
                        position: "bottom",
                        labels: {
                            font: { size: 14, weight: "bold" }
                        }
                    }
                }
            }
        });
    </script>
}
