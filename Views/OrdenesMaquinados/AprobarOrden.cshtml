@model IEnumerable<MaintenenceSystem.Models.OrdenesMaquinados>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="row">
    <div class="col-4">
        <div class="card mx-auto text-center shadow-lg bg-secondary border-0 rounded rounded-pill p-2">
            <h3 class="m-0 fw-bold text-light"><i class="bi bi-clipboard2-check"></i> Gestionar Ordenes de Maquinados</h3>
        </div>
    </div>
</div>
<div class="row">
    <div class="card mb-4 mt-3 p-4 rounded-3 shadow-lg">

        @if (Model != null && Model.Any())
        {
            <div class="row dt-row mt-3">
                <div class="table-responsive col-sm-12">
                    <table id="Main" class="table table-striped table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Folio</th>
                                <th>Requisitor</th>
                                <th>Fecha Solicitud</th>
                                <th>Area</th>
                                <th>Tipo</th>
                                <th>Prioridad</th>
                                <th>Cantidad</th>
                                <th>Descripcion</th>
                                <th>Status</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="
                                        @(item.Status == "Pendiente" ? "table-secondary" : "")
                                        @(item.Status == "En proceso" ? "table-primary" : "")
                                        @(item.Status == "Pausada" ? "table-warning" : "")
                                        @(item.Status == "Cancelada" ? "table-danger" : "")
                                        @(item.Status == "Cerrada" ? "table-success" : "")
                                    ">
                                    <td class="fw-bold">@item.Folio</td>
                                    <td>@item.Requisitor (@item.NumeroEmpleado)</td>
                                    <td>@item.FechaInicio?.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Area</td>
                                    <td>@item.Tipo</td>
                                    <td>@item.Prioridad</td>
                                    <td>@item.Cantidad</td>
                                    <td>@item.Descripcion</td>
                                    <td>
                                        @if (item.Status == "Pendiente")
                                        {
                                            <span class="badge bg-secondary">Pendiente</span>
                                        }
                                        else if (item.Status == "En proceso")
                                        {
                                            <span class="badge bg-primary">En proceso</span>
                                        }
                                        else if (item.Status == "Pausada")
                                        {
                                            <span class="badge bg-warning text-dark">Pausada</span>
                                        }
                                        else if (item.Status == "Cancelada")
                                        {
                                            <span class="badge bg-danger">Cancelada</span>
                                        }
                                        else if (item.Status == "Cerrada")
                                        {
                                            <span class="badge bg-success">Cerrada</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == "Pendiente")
                                        {
                                            <button class="btn btn-primary btn-sm rounded-pill"
                                                    onclick="abrirModalTomar(@item.ID)">
                                                Tomar
                                            </button>
                                        }
                                        else if (item.Status == "En proceso")
                                        {
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-success btn-sm rounded-pill"
                                                        onclick="abrirModalCerrar(@item.ID)">
                                                    Cerrar
                                                </button>

                                                <button class="btn btn-warning btn-sm text-dark rounded-pill"
                                                        onclick="abrirModalPausar(@item.ID)">
                                                    Pausar
                                                </button>

                                                <button class="btn btn-danger btn-sm rounded-pill"
                                                        onclick="abrirModalCancelar(@item.ID)">
                                                    Cancelar
                                                </button>

                                                <button class="btn btn-secondary btn-sm rounded-pill"
                                                        onclick="abrirModalComentarios(@item.ID)">
                                                    Comentarios
                                                </button>
                                            </div>
                                        }
                                        else if (item.Status == "Pausada")
                                        {
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-primary btn-sm rounded-pill"
                                                        onclick="abrirModalReanudar(@item.ID)">
                                                    Reanudar
                                                </button>

                                                <button class="btn btn-danger btn-sm rounded-pill"
                                                        onclick="abrirModalCancelar(@item.ID)">
                                                    Cancelar
                                                </button>

                                                <button class="btn btn-secondary btn-sm rounded-pill"
                                                        onclick="abrirModalComentarios(@item.ID)">
                                                    Comentarios
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin acciones</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <p>No hay ordenes registradas.</p>
        }
    </div>
</div>

<div class="position-fixed bottom-0 end-0 p-4" style="z-index: 9999">
    <div id="OrdenToast" class="toast text-white toast-slide bg-success border-0 fade" role="alert" data-bs-delay="3500">
        <div class="d-flex align-items-center">
            <div class="toast-body d-flex align-items-center gap-2">
                <span id="ToastIcon" style="font-size: 1.5rem;">✔️</span>
                <span id="ToastMensaje">Mensaje</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<div class="modal fade" id="ModalReanudarOrden" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Reanudar orden</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Deseas reanudar esta orden y cambiar su estatus a <strong>En proceso</strong>?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="btnConfirmarReanudar">Confirmar</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalTomarOrden" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Confirmar acción</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Deseas tomar esta orden y cambiar su estatus a <strong>En proceso</strong>?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-primary rounded-pill" id="btnConfirmarTomar">Confirmar</button>
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>

            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalPausarOrden" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Pausar orden</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <p>¿Deseas pausar esta orden y cambiar su estatus a <strong>Pausada</strong>?</p>

                <input type="hidden" id="PausaID" />

                <textarea id="PausaComentario"
                          class="form-control"
                          rows="3"
                          maxlength="100"
                          placeholder="Motivo de la pausa (máx. 100 caracteres)">
                </textarea>

                <small id="PausaCount" class="text-muted">0 / 100</small>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-warning rounded-pill" id="btnConfirmarPausar">Pausar</button>
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalCancelarOrden" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Cancelar orden</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <p>¿Deseas cancelar esta orden y cambiar su estatus a <strong>Cancelada</strong>?</p>

                <input type="hidden" id="CancelarID" />

                <textarea id="CancelarComentario"
                          class="form-control"
                          rows="3"
                          maxlength="100"
                          placeholder="Motivo de la cancelación (máx. 100 caracteres)">
                </textarea>

                <small id="CancelarCount" class="text-muted">0 / 100</small>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger rounded-pill" id="btnConfirmarCancelar">Cancelar orden</button>
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalCerrarOrden" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Cerrar orden</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Deseas cerrar esta orden y cambiar su estatus a <strong>Cerrada</strong>?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-success rounded-pill" id="btnConfirmarCerrar">Confirmar</button>
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ComentariosModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            @Html.AntiForgeryToken()

            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title">Agregar comentario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="ComentarioID" />

                <label class="form-label fw-semibold">Comentario (máx. 100 caracteres)</label>
                <textarea id="ComentarioTexto" class="form-control" rows="3" maxlength="100"></textarea>

                <small id="ComentarioCount" class="text-muted">0 / 100</small>
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary rounded-pill" onclick="guardarComentario()">Guardar comentario</button>
                <button class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            $('#Main').DataTable({
                pageLength: 10,
                order: [],
                responsive: true,
                autoWidth: false,
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

        });
    </script>

    <script>
        let ordenIdReanudar = 0;

        function abrirModalReanudar(id) {
            ordenIdReanudar = id;

            var modal = new bootstrap.Modal(document.getElementById('ModalReanudarOrden'));
            modal.show();
        }

        document.getElementById("btnConfirmarReanudar").addEventListener("click", function () {

            fetch(`/OrdenesMaquinados/ReanudarOrden/${ordenIdReanudar}`, {
                method: "POST"
            })
            .then(response => {
                if (response.ok) {
                    window.location.reload();
                }
            });
        });
    </script>

    <script>
        let ordenIdSeleccionada = 0;

        function abrirModalTomar(id) {
            ordenIdSeleccionada = id;

            var modal = new bootstrap.Modal(document.getElementById('ModalTomarOrden'));
            modal.show();
        }

        document.getElementById("btnConfirmarTomar").addEventListener("click", function () {

            fetch(`/OrdenesMaquinados/TomarOrden/${ordenIdSeleccionada}`, {
                method: "POST"
            })
            .then(response => {
                if (response.ok) {
                    window.location.reload();
                }
            });
        });
    </script>

    <script>
        function abrirModalPausar(id) {
            document.getElementById("PausaID").value = id;
            document.getElementById("PausaComentario").value = "";
            document.getElementById("PausaCount").textContent = "0 / 100";

            var modal = new bootstrap.Modal(document.getElementById("ModalPausarOrden"));
            modal.show();
        }

        document.getElementById("PausaComentario").addEventListener("input", function () {
            document.getElementById("PausaCount").textContent = this.value.length + " / 100";
        });

        document.getElementById("btnConfirmarPausar").addEventListener("click", function () {

            var id = document.getElementById("PausaID").value;
            var comentario = document.getElementById("PausaComentario").value.trim();

            if (comentario.length === 0) {
                mostrarToast("Debes escribir un comentario", "warning", "⚠️");
                return;
            }

            fetch('/OrdenesMaquinados/PausarConComentario', {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({
                    id: id,
                    comentario: comentario
                })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {

                    bootstrap.Modal.getInstance(document.getElementById("ModalPausarOrden")).hide();

                    mostrarToast("Orden pausada", "warning", "⏸️");

                    setTimeout(() => location.reload(), 800);
                }
            });
        });
    </script>

    <script>
        function abrirModalCancelar(id) {
            document.getElementById("CancelarID").value = id;
            document.getElementById("CancelarComentario").value = "";
            document.getElementById("CancelarCount").textContent = "0 / 100";

            var modal = new bootstrap.Modal(document.getElementById("ModalCancelarOrden"));
            modal.show();
        }

        document.getElementById("CancelarComentario").addEventListener("input", function () {
            document.getElementById("CancelarCount").textContent = this.value.length + " / 100";
        });

        document.getElementById("btnConfirmarCancelar").addEventListener("click", function () {

            var id = document.getElementById("CancelarID").value;
            var comentario = document.getElementById("CancelarComentario").value.trim();

            if (comentario.length === 0) {
                mostrarToast("Debes escribir un comentario", "warning", "⚠️");
                return;
            }

            fetch('/OrdenesMaquinados/CancelarOrden', {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({
                    id: id,
                    comentario: comentario
                })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {

                    bootstrap.Modal.getInstance(document.getElementById("ModalCancelarOrden")).hide();

                    mostrarToast("Orden cancelada", "danger", "⛔");

                    setTimeout(() => location.reload(), 800);
                }
            });
        });
    </script>

    <script>
        let ordenIdCerrar = 0;

        function abrirModalCerrar(id) {
            ordenIdCerrar = id;

            var modal = new bootstrap.Modal(document.getElementById('ModalCerrarOrden'));
            modal.show();
        }

        document.getElementById("btnConfirmarCerrar").addEventListener("click", function () {

            fetch(`/OrdenesMaquinados/CerrarOrden/${ordenIdCerrar}`, {
                method: "POST"
            })
            .then(response => {
                if (response.ok) {
                    window.location.reload();
                }
            });
        });
    </script>

    <script>
        function mostrarToast(mensaje, color, icono) {
            const toast = document.getElementById("OrdenToast");
            const msg = document.getElementById("ToastMensaje");
            const ico = document.getElementById("ToastIcon");

            // Cambiar mensaje, color e icono
            msg.textContent = mensaje;
            ico.textContent = icono;

            toast.classList.remove("bg-success", "bg-danger", "bg-warning", "bg-primary", "bg-info");
            toast.classList.add("bg-" + color);

            new bootstrap.Toast(toast).show();
        }
    </script>

    <script>
        function abrirModalComentarios(id) {
            document.getElementById("ComentarioID").value = id;
            document.getElementById("ComentarioTexto").value = "";
            document.getElementById("ComentarioCount").textContent = "0 / 100";

            var modal = new bootstrap.Modal(document.getElementById("ComentariosModal"));
            modal.show();
        }

        document.getElementById("ComentarioTexto").addEventListener("input", function () {
            document.getElementById("ComentarioCount").textContent = this.value.length + " / 100";
        });
    </script>

    <script>
        function guardarComentario() {
            var id = document.getElementById("ComentarioID").value;
            var comentario = document.getElementById("ComentarioTexto").value.trim();

            if (comentario.length === 0) {
                mostrarToast("El comentario no puede estar vacío", "warning", "⚠️");
                return;
            }

            fetch('/OrdenesMaquinados/GuardarComentario', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({
                    id: id,
                    comentario: comentario
                })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {

                    bootstrap.Modal.getInstance(document.getElementById("ComentariosModal")).hide();

                    mostrarToast("Comentario guardado", "info", "💬");

                    setTimeout(() => location.reload(), 800);
                }
            });
        }
    </script>
}
@if (TempData["OrdenTomada"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            mostrarToast("Orden tomada correctamente", "primary", "🛠️");
        });
    </script>
}

@if (TempData["OrdenCerrada"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            mostrarToast("Orden cerrada correctamente", "success", "✔️");
        });
    </script>
}

@if (TempData["OrdenPausada"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            mostrarToast("Orden pausada", "warning", "⏸️");
        });
    </script>
}

@if (TempData["OrdenCancelada"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            mostrarToast("Orden cancelada", "danger", "❌");
        });
    </script>
}