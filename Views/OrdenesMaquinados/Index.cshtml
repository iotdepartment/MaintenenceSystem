@model IEnumerable<MaintenenceSystem.Models.OrdenesMaquinados>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />


<div class="row">
    <div class="col-4">
        <div class="card mx-auto text-center shadow-lg bg-secondary border-0 rounded rounded-pill p-2">
            <h3 class="m-0 fw-bold text-light"><i class="bi bi-card-list">  </i>Status de Ordenes de Maquinados</h3>
        </div>
    </div>
</div>
<div class="row">
    <div class="card mb-4 mt-3 p-4 rounded-3 shadow-lg">
        <div class="row mt-2 mb-3">
            <div class="col-12">
                <button class="btn btn-success rounded-pill shadow-sm fw-semibold"
                        data-bs-toggle="modal" data-bs-target="#CreateOrdenModal">
                    <i class="bi bi-plus-circle me-2"></i>
                    Nueva Orden
                </button>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row dt-row mt-3">
                <div class="table-responsive col-sm-12">
                    <table id="Main" class="table table-striped table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Folio</th>
                                <th>Requisitor</th>
                                <th>Fecha Solicitud</th>
                                <th>Fecha Aceptacion</th>
                                <th>Fecha Entrega</th>
                                <th>Area</th>
                                <th>Tipo</th>
                                <th>Prioridad</th>
                                <th>Cantidad</th>
                                <th>Descripcion</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="
                                        @(item.Status == "Pendiente" ? "table-secondary" : "")
                                        @(item.Status == "En proceso" ? "table-primary" : "")
                                        @(item.Status == "Pausada" ? "table-warning" : "")
                                        @(item.Status == "Cancelada" ? "table-danger" : "")
                                        @(item.Status == "Cerrada" ? "table-success" : "")
                                    ">
                                    <td class="fw-bolder">@item.Folio</td>
                                    <td>@item.Requisitor (@item.NumeroEmpleado)</td>
                                    <td>@item.FechaInicio?.ToString("dd/MM/yyyy")</td>
                                    <td>@item.FechaAceptacion?.ToString("dd/MM/yyyy")</td>
                                    <td>@item.FechaEntrega?.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Area</td>
                                    <td>@item.Tipo</td>
                                    <td>@item.Prioridad</td>
                                    <td>@item.Cantidad</td>
                                    <td>@item.Descripcion</td>
                                    <td>
                                        @if (item.Status == "Pendiente")
                                        {
                                            <span class="badge bg-secondary fs-6"
                                                  style="cursor:pointer"
                                                  onclick="verHistorial(@item.ID)">
                                                ⏳ Pendiente
                                            </span>
                                        }
                                        else if (item.Status == "En proceso")
                                        {
                                            <span class="badge bg-primary fs-6"
                                                  style="cursor:pointer"
                                                  onclick="verHistorial(@item.ID)">
                                                🔧 En proceso
                                            </span>
                                        }
                                        else if (item.Status == "Pausada")
                                        {
                                            <span class="badge bg-warning text-dark fs-6"
                                                  style="cursor:pointer"
                                                  onclick="verHistorial(@item.ID)">
                                                ⏸️ Pausada
                                            </span>
                                        }
                                        else if (item.Status == "Cancelada")
                                        {
                                            <span class="badge bg-danger fs-6"
                                                  style="cursor:pointer"
                                                  onclick="verHistorial(@item.ID)">
                                                ❌ Cancelada
                                            </span>
                                        }
                                        else if (item.Status == "Cerrada")
                                        {
                                            <span class="badge bg-success fs-6"
                                                  style="cursor:pointer"
                                                  onclick="verHistorial(@item.ID)">
                                                ✔️ Cerrada
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <p>No hay ordenes registradas.</p>
        }
    </div>
</div>

<div class="position-fixed bottom-0 end-0 p-4" style="z-index: 9999">
    <div id="OrdenCreadaToast" class="toast text-white bg-success border-0 fade" role="alert" data-bs-delay="3500">
        <div class="d-flex align-items-center">
            <div class="toast-body d-flex align-items-center gap-2">
                <span style="font-size: 1.5rem;">✔️</span>
                <span>Orden creada correctamente</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<div class="modal fade" id="ModalHistorial" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Historial de la Orden</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="HistorialContenido">
                <!-- Aquí se cargará la vista parcial -->
            </div>

        </div>
    </div>
</div>

@await Html.PartialAsync("_CreateOrdenModal", new MaintenenceSystem.Models.OrdenesMaquinados())

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            $('#Main').DataTable({
                pageLength: 10,
                order: [],
                responsive: true,
                autoWidth: false,
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

        });
    </script>

    <script>

        var modal = document.getElementById('CreateOrdenModal');

        modal.addEventListener('shown.bs.modal', function () {

            var inputNumero = document.getElementById("NumeroEmpleado");
            var inputRequisitor = document.getElementById("Requisitor");
            var btnGenerar = document.getElementById("btnGenerarOrden");
            var errorMsg = document.getElementById("NumeroEmpleadoError");

            btnGenerar.disabled = true;

            inputNumero.addEventListener("input", function () {

                // Solo permitir números
                this.value = this.value.replace(/[^0-9]/g, '');

                // Limitar a 5 dígitos
                if (this.value.length > 5) {
                    this.value = this.value.slice(0, 5);
                }

                var numero = this.value.trim();

                // Si está vacío → inválido
                if (numero.length === 0) {
                    inputRequisitor.value = "";
                    btnGenerar.disabled = true;
                    inputNumero.classList.remove("is-valid");
                    inputNumero.classList.add("is-invalid");
                    errorMsg.classList.remove("d-none");
                    errorMsg.textContent = "Ingrese un número de empleado";
                    return;
                }

                // Buscar empleado desde 1 dígito
                fetch(`/OrdenesMaquinados/ObtenerEmpleado?numero=${numero}`)
                    .then(response => response.json())
                    .then(data => {

                        if (data.success) {
                            inputRequisitor.value = data.nombre;

                            inputNumero.classList.remove("is-invalid");
                            inputNumero.classList.add("is-valid");
                            errorMsg.classList.add("d-none");

                            btnGenerar.disabled = false;

                        } else {
                            inputRequisitor.value = "";

                            inputNumero.classList.remove("is-valid");
                            inputNumero.classList.add("is-invalid");
                            errorMsg.classList.remove("d-none");
                            errorMsg.textContent = "Empleado no encontrado";

                            btnGenerar.disabled = true;
                        }
                    });
            });

        });


        // ================================
        // VALIDACIÓN DE DESCRIPCIÓN
        // ================================
        var descripcion = document.getElementById("Descripcion");
        var contador = document.getElementById("DescripcionCount");

        descripcion.addEventListener("input", function () {

            // Limitar a 350 caracteres
            if (this.value.length > 350) {
                this.value = this.value.slice(0, 350);
            }

            // Primera letra mayúscula, resto minúsculas
            let texto = this.value;
            if (texto.length > 0) {
                this.value = texto.charAt(0).toUpperCase() + texto.slice(1).toLowerCase();
            }

            // Auto‑resize
            this.style.height = "auto";
            this.style.height = this.scrollHeight + "px";

            // Actualizar contador
            contador.textContent = this.value.length + " / 350";
        });

        function verHistorial(id) {
            fetch('/OrdenesMaquinados/HistorialComentarios?id=' + id)
                .then(r => r.text())
                .then(html => {
                    document.getElementById("HistorialContenido").innerHTML = html;
                    new bootstrap.Modal(document.getElementById("ModalHistorial")).show();
                });
        }

    </script>
}

@if (!ViewData.ModelState.IsValid)
{
    <script>
        var modal = new bootstrap.Modal(document.getElementById('CreateOrdenModal'));
        modal.show();
    </script>
}

@if (TempData["OrdenCreada"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var toastEl = document.getElementById('OrdenCreadaToast');
            var toast = new bootstrap.Toast(toastEl);
            toast.show();
        });
    </script>
}